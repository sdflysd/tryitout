# TryItOut environment template.
# Copy this file to frontend/.env and replace placeholder secrets before running.

# ---------------------------------------------------------------------------
# App runtime
# ---------------------------------------------------------------------------

# The public URL used for self-referential links. For local development:
APP_URL="http://localhost:3000"

# Optional. The API always listens on container/local port 3000 today.
NODE_ENV="development"

# ---------------------------------------------------------------------------
# AI provider
# ---------------------------------------------------------------------------

# Supported: gemini, anthropic, openai_compatible
AI_PROVIDER="gemini"

# Required when AI_PROVIDER="gemini".
GEMINI_API_KEY="replace-with-gemini-api-key"

# Required when AI_PROVIDER="anthropic".
ANTHROPIC_API_KEY="replace-with-anthropic-api-key"

# Required when AI_PROVIDER="openai_compatible".
# Base URL is server-side only and must not be sent to the browser.
OPENAI_COMPATIBLE_API_KEY="replace-with-openai-compatible-api-key"
OPENAI_COMPATIBLE_BASE_URL="https://api.openai.com/v1"
OPENAI_COMPATIBLE_MODEL_FAST="gpt-4o-mini"
OPENAI_COMPATIBLE_MODEL_BALANCED="gpt-4o"
OPENAI_COMPATIBLE_MODEL_DEEP="gpt-4o"

# Optional. Set to "true" only while debugging prompts/model responses.
# Output can contain user input and model output.
ENABLE_AGENT_DEBUG_LOGS="false"

# Optional. Set to "true" to allow deep Agent interaction mode.
ENABLE_AGENT_INTERACTION_MODE="false"

# ---------------------------------------------------------------------------
# Commercial mode
# ---------------------------------------------------------------------------

# Leave "false" for the local file-backed demo path.
# Set "true" for Docker/production deployments with Postgres and Redis.
COMMERCIAL_MODE_ENABLED="false"

# Required when COMMERCIAL_MODE_ENABLED="true".
# Local host development can use localhost. Docker Compose overrides these to
# postgres/redis service hostnames inside containers.
DATABASE_URL="postgres://tryitout:tryitout@localhost:5432/tryitout"
REDIS_URL="redis://localhost:6379"

# Required commercial secrets. Generate real values before deployment:
#   openssl rand -hex 32
#   openssl rand -base64 32
SESSION_SECRET="replace-with-at-least-32-random-characters"
ACCESS_CODE_PEPPER="replace-with-at-least-32-random-characters"
USER_SECRET_ENCRYPTION_KEY="replace-with-base64-32-byte-key"

# Optional comma-separated host allowlist for user-owned OpenAI-compatible
# provider base URLs. Empty means the app only applies built-in URL safety.
ALLOWED_MODEL_PROVIDER_HOSTNAMES=""

# ---------------------------------------------------------------------------
# Docker Compose Postgres/Redis defaults
# ---------------------------------------------------------------------------

POSTGRES_USER="tryitout"
POSTGRES_PASSWORD="tryitout"
POSTGRES_DB="tryitout"

# ---------------------------------------------------------------------------
# Queue, worker, and pricing knobs
# ---------------------------------------------------------------------------

MAX_WEIGHTED_CONCURRENCY="30"
SIMULATION_WORKER_ID="worker_1"
SIMULATION_WORKER_CONCURRENCY="1"

PLATFORM_LEGACY_CREDIT_COST="1"
PLATFORM_DEEP_CREDIT_COST="3"
BYOK_LEGACY_CREDIT_COST="1"
BYOK_DEEP_CREDIT_COST="2"

# ---------------------------------------------------------------------------
# Admin bootstrap
# ---------------------------------------------------------------------------

# Used by npm run seed:admin or npm run seed:admin:dist.
ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="replace-with-temporary-admin-password"
ADMIN_ROLE="owner"
ADMIN_TIER="business"
ADMIN_FEATURES="admin_ops"
ADMIN_INITIAL_CREDITS="0"
