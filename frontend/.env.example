# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI_PROVIDER: Optional backend provider selector.
# Supported: gemini, anthropic, openai_compatible
AI_PROVIDER="gemini"

# ANTHROPIC_API_KEY: Required when AI_PROVIDER="anthropic".
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# OPENAI_COMPATIBLE_*: Required when AI_PROVIDER="openai_compatible".
# Base URL is server-side only and must not be sent by the frontend.
OPENAI_COMPATIBLE_API_KEY="MY_OPENAI_COMPATIBLE_API_KEY"
OPENAI_COMPATIBLE_BASE_URL="https://api.openai.com/v1"
OPENAI_COMPATIBLE_MODEL_FAST="gpt-4o-mini"
OPENAI_COMPATIBLE_MODEL_BALANCED="gpt-4o"
OPENAI_COMPATIBLE_MODEL_DEEP="gpt-4o"

# ENABLE_AGENT_DEBUG_LOGS: Optional. Set to "true" to write raw AI prompts and
# responses to ../output/agent-debug/<simulationId>/agent-debug.jsonl.
# This can include user input and model output; keep disabled outside debugging.
ENABLE_AGENT_DEBUG_LOGS="false"

# ENABLE_AGENT_INTERACTION_MODE: Optional. Set to "true" to allow deep Agent
# interaction mode when the user requests it. When false or missing, requests
# use the faster legacy staged simulation path.
ENABLE_AGENT_INTERACTION_MODE="false"

# Commercial MVP mode. Leave disabled for local demo/file-backed simulation.
# When enabled, startup requires Postgres, Redis, and the secrets below.
COMMERCIAL_MODE_ENABLED="false"
VITE_COMMERCIAL_MODE_ENABLED="false"
DATABASE_URL="postgres://tryitout:tryitout@localhost:5432/tryitout"
REDIS_URL="redis://localhost:6379"
SESSION_SECRET="replace-with-a-long-random-session-secret"
ACCESS_CODE_PEPPER="replace-with-a-long-random-access-code-pepper"
# 32 random bytes, base64 encoded. Example: openssl rand -base64 32
USER_SECRET_ENCRYPTION_KEY="replace-with-base64-32-byte-key"

# Commercial queue and credit pricing knobs.
MAX_WEIGHTED_CONCURRENCY="6"
PLATFORM_LEGACY_CREDIT_COST="1"
PLATFORM_DEEP_CREDIT_COST="3"
BYOK_LEGACY_CREDIT_COST="1"
BYOK_DEEP_CREDIT_COST="2"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Commercial platform mode: Optional. Set to "true" only when production
# backing services and secrets are configured.
COMMERCIAL_MODE_ENABLED="false"

# Commercial backing services: Required when COMMERCIAL_MODE_ENABLED="true".
DATABASE_URL="postgres://tryitout:test@localhost:5432/tryitout"
REDIS_URL="redis://localhost:6379"

# Commercial secrets: Required when COMMERCIAL_MODE_ENABLED="true".
# SESSION_SECRET and ACCESS_CODE_PEPPER should be high-entropy strings.
# USER_SECRET_ENCRYPTION_KEY must be a base64-encoded 32-byte key.
SESSION_SECRET="replace-with-at-least-32-characters"
ACCESS_CODE_PEPPER="replace-with-at-least-32-characters"
USER_SECRET_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Commercial worker budget: Optional. Defaults to 30.
MAX_WEIGHTED_CONCURRENCY="30"
