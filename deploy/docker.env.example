# Copy this file to deploy/docker.env before running docker compose.

APP_URL="http://localhost:8080"

# Supported: gemini, anthropic, openai_compatible
AI_PROVIDER="gemini"
GEMINI_API_KEY="replace-with-gemini-api-key"
ANTHROPIC_API_KEY="replace-with-anthropic-api-key"
OPENAI_COMPATIBLE_API_KEY="replace-with-openai-compatible-api-key"
OPENAI_COMPATIBLE_BASE_URL="https://api.openai.com/v1"
OPENAI_COMPATIBLE_MODEL_FAST="gpt-4o-mini"
OPENAI_COMPATIBLE_MODEL_BALANCED="gpt-4o"
OPENAI_COMPATIBLE_MODEL_DEEP="gpt-4o"

ENABLE_AGENT_DEBUG_LOGS="false"
ENABLE_AGENT_INTERACTION_MODE="false"

COMMERCIAL_MODE_ENABLED="true"
DATABASE_URL="postgres://tryitout:tryitout@postgres:5432/tryitout"
REDIS_URL="redis://redis:6379"

POSTGRES_USER="tryitout"
POSTGRES_PASSWORD="tryitout"
POSTGRES_DB="tryitout"

# Generate production values:
#   openssl rand -hex 32
#   openssl rand -base64 32
SESSION_SECRET="replace-with-at-least-32-random-characters"
ACCESS_CODE_PEPPER="replace-with-at-least-32-random-characters"
USER_SECRET_ENCRYPTION_KEY="replace-with-base64-32-byte-key"
ALLOWED_MODEL_PROVIDER_HOSTNAMES=""

MAX_WEIGHTED_CONCURRENCY="30"
SIMULATION_WORKER_ID="worker_1"
SIMULATION_WORKER_CONCURRENCY="1"

PLATFORM_LEGACY_CREDIT_COST="1"
PLATFORM_DEEP_CREDIT_COST="3"
BYOK_LEGACY_CREDIT_COST="1"
BYOK_DEEP_CREDIT_COST="2"

ADMIN_EMAIL="owner@example.com"
ADMIN_PASSWORD="replace-with-temporary-admin-password"
ADMIN_ROLE="owner"
ADMIN_TIER="business"
ADMIN_FEATURES="admin_ops"
ADMIN_INITIAL_CREDITS="0"
